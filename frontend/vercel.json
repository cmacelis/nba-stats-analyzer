    { "source": "/api/nba/players", "destination": "/api/players?league=nba" },
    { "source": "/api/nba/players/(.*)", "destination": "/api/players?_subpath=$1&league=nba" },
    { "source": "/api/nba/games", "destination": "/api/players?_subpath=games&league=nba" },
    { "source": "/api/nba/research/(.*)", "destination": "/api/players?_subpath=research/$1&league=nba" },
    { "source": "/api/wnba/players", "destination": "/api/players?league=wnba" },
    { "source": "/api/wnba/players/(.*)", "destination": "/api/players?_subpath=$1&league=wnba" },
    { "source": "/api/wnba/games", "destination": "/api/players?_subpath=games&league=wnba" },
    { "source": "/api/wnba/research/(.*)", "destination": "/api/players?_subpath=research/$1&league=wnba" },
    { "source": "/api/wnba/edge", "destination": "/api/edge?league=wnba" },
    { "source": "/api/core/nba/players", "destination": "/api/players?league=nba" },
    { "source": "/api/core/nba/players/(.*)", "destination": "/api/players?_subpath=$1&league=nba" },
    { "source": "/api/core/wnba/players", "destination": "/api/players?league=wnba" },
    { "source": "/api/core/wnba/players/(.*)", "destination": "/api/players?_subpath=$1&league=wnba" },
    { "source": "/api/notifications/(.*)", "destination": "/api/favorites?_subpath=notifications/$1" },
    { "source": "/api/games", "destination": "/api/players?_subpath=games" },
    { "source": "/api/games/(.*)", "destination": "/api/players?_subpath=games/$1" },
    { "source": "/api/predict", "destination": "/api/players?_subpath=predict" },
