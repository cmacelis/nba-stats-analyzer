# Backend origin — no trailing slash, no /api suffix.
# In development this is left empty; the Vite dev server proxies /api/* to localhost:3000.
# In production set this in Vercel → Project Settings → Environment Variables.
VITE_API_BASE_URL=http://localhost:3000

# Vercel KV (Redis) — required for cross-device pick tracking + alert cooldowns.
# Run `vercel kv create nba-picks` then `vercel env pull` to populate automatically.
# Without these the /api/picks endpoint returns { data: [], configured: false }
# and the app degrades to browser-local prediction counts only.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Discord ───────────────────────────────────────────────────────────────────
# DISCORD_WEBHOOK_URL scopes all alerts + digests to the channel where the
# webhook was created (Server Settings → Integrations → Webhooks → New Webhook).
# To route different message types to different channels, create separate webhooks
# and set DISCORD_TODAY_WEBHOOK_URL / DISCORD_HELP_WEBHOOK_URL as overrides.
DISCORD_WEBHOOK_URL=

# Endpoints (all POST-only, use the same webhook URL):
#   POST /api/alerts/run?stat=pts&direction=both&min_delta=2.0
#   POST /api/discord/today?stat=pts&top_n=5      ← daily top-5 digest
#   POST /api/discord/help                         ← pinnable how-it-works embed

# Alert thresholds (all optional — these are the defaults).
ALERT_MIN_DELTA_PTS=2.0
ALERT_MIN_DELTA_PRA=3.5
ALERT_COOLDOWN_MINUTES=180

# Public site URL for embed deep-links (auto-detected from VERCEL_URL in most cases).
# Only needed if your deployment URL differs from the Vercel-assigned domain.
SITE_URL=

# ── Admin Dashboard ────────────────────────────────────────────────────────
# Comma-separated list of emails that can access /admin.
# Set in Vercel → Project Settings → Environment Variables.
ADMIN_EMAILS=
